rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles (friend code, settings) ──────────────
    match /users/{userId} {
      // Only the owner can write; friends can read for code lookup
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Habits (private) ─────────────────────────────────
      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Logs (private) ───────────────────────────────────
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Public stats (opt-in, read by any authenticated user) ─
      match /public_stats/{statDoc} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Friend requests (global collection) ─────────────────
    match /friend_requests/{reqId} {
      // Sender or recipient can read
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
         || request.auth.uid == resource.data.toUid);

      // Only the sender can create
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;

      // Only the recipient can update status
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // No deletion
      allow delete: if false;
    }
  }
}
