rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. USER PROFILES ---
    // Allow users to access only their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // --- 2. LICENSE KEYS ---
    match /license_keys/{keyId} {
      // Allow reading keys to check validity
      allow read: if request.auth != null;
      
      // Allow updating keys (to mark them as 'claimed')
      allow update: if request.auth != null;
      
      // Block users from creating new keys or deleting existing ones
      allow create, delete: if false;
    }
    
    // --- 3. HABITS ---
    match /users/{userId}/habits/{habitId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // --- 4. LOGS ---
    match /users/{userId}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
